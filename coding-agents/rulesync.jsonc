{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/config-schema.json",
  "targets": {
    "agentsmd": [
      "*"
    ],
    "agentsskills": [
      "*"
    ],
    "cursor": [
      "*"
    ],
    "claudecode": [
      "rules",
      "ignore",
      "mcp",
      "commands",
      "subagents",
      "skills",
      "hooks",
      "permissions"
    ],
    "opencode": [
      "rules",
      "mcp",
      "commands",
      "subagents",
      "skills",
      "hooks"
    ],
    "copilotcli": [
      "*"
    ],
    "codexcli": [
      "rules",
      "mcp",
      "commands",
      "subagents",
      "skills",
      "hooks",
      "permissions"
    ]
  },
  "outputRoots": [
    "."
  ],
  "delete": true,
  "verbose": true,
  "silent": false,
  "global": true,
  "simulateCommands": false,
  "simulateSubagents": false,
  "simulateSkills": false,
  "gitignoreTargetsOnly": true,
  // Declarative skill sources — installed via 'rulesync install'
  // See the "Declarative Skill Sources" section for details.
  "sources": [
    {
      "source": "dyoshikawa/rulesync",
      "skills": [
        "rulesync"
      ]
    },
    {
      "source": "https://github.com/blader/humanizer",
      "transport": "git",
      "path": ".",
      "skills": ["humanizer"]
    },
    {
      "source": "mattpocock/skills:skills/productivity",
      "skills": [
        "write-a-skill",
        "handoff",
        "teach"
      ]
    },
    {
      "source": "mattpocock/skills:skills/personal",
      "skills": [
        "edit-article",
        "obsidian-vault"
      ]
    },
    {
      "source": "mattpocock/skills:skills/engineering",
      "skills": [
        "grill-with-docs",
        "improve-codebase-architecture",
        "prototype",
        "tdd",
        "to-issues",
        "to-prd",
        "triage",
        "zoom-out",
        "diagnose"
      ]
    }
  ]
}
