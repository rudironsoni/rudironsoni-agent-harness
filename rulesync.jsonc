{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/config-schema.json",
  "targets": {
    "agentsmd": [
      "*"
    ],
    "agentsskills": [
      "*"
    ],
    "cursor": [
      "*"
    ],
    "claudecode": [
      "*"
    ],
    "opencode": [
      "*"
    ],
    "copilotcli": [
      "*"
    ],
    "codexcli": [
      "*"
    ]
  },
  "outputRoots": [
    "."
  ],
  "delete": true,
  "verbose": true,
  "silent": false,
  "global": true,
  "simulateCommands": false,
  "simulateSubagents": false,
  "simulateSkills": false,
  "gitignoreTargetsOnly": true,
  // Declarative skill sources — installed via 'rulesync install'
  // See the "Declarative Skill Sources" section for details.
  "sources": [
    {
      "source": "dyoshikawa/rulesync",
      "skills": [
        "rulesync"
      ]
    },
    {
      "source": "kepano/obsidian-skills"
    },
    {
      "source": "cocoindex-io/cocoindex-code"
    },
    {
      "source": "blader/humanizer",
      "skills": [
        "humanizer"
      ]
    },
    {
      "source": "mattpocock/skills:skills/productivity",
      "skills": [
        "write-a-skill",
        "handoff"
      ]
    },
    {
      "source": "mattpocock/skills:skills/personal",
      "skills": [
        "edit-article",
        "obsidian-vault"
      ]
    },
    {
      "source": "mattpocock/skills:skills/engineering",
      "skills": [
        "grill-with-docs",
        "improve-codebase-architecture",
        "prototype",
        "tdd",
        "to-issues",
        "to-prd",
        "triage",
        "zoom-out",
        "diagnose"
      ]
    }
  ]
}