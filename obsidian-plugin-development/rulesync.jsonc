{
  "$schema": "https://github.com/dyoshikawa/rulesync/releases/latest/download/config-schema.json",
  "targets": [
    "copilot",
    "cursor",
    "claudecode",
    "codexcli",
    "opencode",
    "antigravity-ide"
  ],
  "features": [
    "rules",
    "ignore",
    "mcp",
    "commands",
    "subagents",
    "skills",
    "hooks"
  ],
  "outputRoots": [
    "."
  ],
  "delete": true,
  "verbose": false,
  "silent": false,
  "global": false,
  "simulateCommands": false,
  "simulateSubagents": false,
  "simulateSkills": false,
  "gitignoreTargetsOnly": true,
  "sources": [
    {
      "source": "davidvkimball/obsidian-dev-skills:.",
      "skills": [
        "obsidian-dev",
        "obsidian-ops",
        "obsidian-ref",
        "obsidian-theme-dev"
      ]
    }
  ]
}
